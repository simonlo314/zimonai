{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zimonai-pages",
  "main": "_worker.js",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "kv_namespaces": [
    {
      "binding": "ZA_STATS",
      "id": "d74d8988400d418591862a970fa1e3b3"
    }
  ]
}
